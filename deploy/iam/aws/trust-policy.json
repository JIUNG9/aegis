{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AegisAgentAssumeRoleWithMFAAndExternalId",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::123456789012:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true",
          "aws:SecureTransport": "true"
        },
        "StringEquals": {
          "sts:ExternalId": "REPLACE_WITH_SHARED_SECRET_32_CHARS_MIN"
        },
        "NumericLessThan": {
          "aws:MultiFactorAuthAge": "3600"
        }
      }
    }
  ],
  "_comment": "Replace 123456789012 with YOUR_ACCOUNT_ID. ExternalId must be a shared secret at least 32 characters — generate with: openssl rand -hex 24. MaxSessionDuration should be set to 3600s on the role itself."
}
