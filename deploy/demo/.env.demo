# ────────────────────────────────────────────────────────────────
#  Aegis Demo Mode environment
#
#  These values point at the in-compose services only.
#  NONE of them work against real AWS, Slack, Confluence, or LLM
#  providers. Safe to commit.
# ────────────────────────────────────────────────────────────────

# Demo mode flag
AEGIS_DEMO_MODE=true

# Aegis
API_PORT=8000
DEBUG=true
ANTHROPIC_API_KEY=demo-no-key
MODEL_NAME=claude-sonnet-4-6
OLLAMA_URL=http://ollama:11434

# Observability (SigNoz in-stack)
SIGNOZ_API_URL=http://signoz-query-service:8080
SIGNOZ_API_KEY=demo-key
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4317

# LocalStack (fake AWS)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# Confluence mock
CONFLUENCE_BASE_URL=http://confluence-mock:8090
CONFLUENCE_API_TOKEN=demo-token

# Kill switch
REDIS_URL=redis://redis:6379

# Vault (named volume inside container)
AEGIS_VAULT_PATH=/var/lib/aegis/vault

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SIGNOZ_URL=http://localhost:3301
NEXT_PUBLIC_OTEL_DEMO_URL=http://localhost:8080
